# Root monorepo policy: ignore everything by default, then allow only intended projects
/*

# Keep repository meta and Nx root files
!/.gitignore
!/nx.json
!/package.json
!/package-lock.json
!/project.json
!/README.md

# Deployment scripts and systemd units
!/deploy/
!/deploy/**

# Keep only intended tracked applications/services
!/NT2-chatbot/
!/NT2-chatbot/**
!/dashboard/
!/dashboard/**

!/services/
!/services/api-gateway/
!/services/api-gateway/**
!/services/database-manager/
!/services/database-manager/**
!/services/openai-service/
!/services/openai-service/**

# Explicitly ignore directories you requested to exclude
/chat_app/
/school_chatbot_test/
/school_chatbot__test/
/services/mbo-language-assistant-bot-speech-input-service/
/services/mbo-language-assistant-bot-text-input-service/
/services/mbo-language-assistant-bot-retrieve-service/

# Secrets and local env files
**/.env
**/.env.local
**/.env.*.local
**/.envrc
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/*secrets*.json
**/*secret*.json
**/*credentials*.json

# Track .env.example files (templates with placeholder values)
!**/.env.example

# Python artifacts
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.venv/
**/venv/

# Node artifacts
**/node_modules/
**/build/
**/dist/
**/.npm/
**/.pnpm-store/

# IDE and OS artifacts
**/.idea/
**/.vscode/
**/.DS_Store
**/Thumbs.db

# Logs and temp
**/*.log
**/tmp/
**/temp/
**/.cache/
