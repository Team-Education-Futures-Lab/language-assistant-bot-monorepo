# Root monorepo policy: ignore everything by default, then allow only intended projects
/*

# Keep repository meta and Nx root files
!/.gitignore
!/nx.json
!/package.json
!/package-lock.json
!/project.json

# Keep only intended tracked applications/services
!/mbo-language-assistant-chatbot/
!/mbo-language-assistant-chatbot/**
!/mbo-language-assistant-dashboard/
!/mbo-language-assistant-dashboard/**

!/services/
!/services/mbo-language-assistant-bot-api-gateway/
!/services/mbo-language-assistant-bot-api-gateway/**
!/services/mbo-language-assistant-bot-database-manager/
!/services/mbo-language-assistant-bot-database-manager/**
!/services/mbo-language-assistant-bot-realtime-voice-service/
!/services/mbo-language-assistant-bot-realtime-voice-service/**
!/services/mbo-language-assistant-bot-retrieve-service/
!/services/mbo-language-assistant-bot-retrieve-service/**

# Explicitly ignore directories you requested to exclude
/chat_app/
/school_chatbot_test/
/school_chatbot__test/
/services/mbo-language-assistant-bot-speech-input-service/
/services/mbo-language-assistant-bot-text-input-service/

# Secrets and local env files
**/.env
**/.env.*
**/.envrc
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/*secrets*.json
**/*secret*.json
**/*credentials*.json

# One template currently contains a real key: do not track it
/services/mbo-language-assistant-bot-realtime-voice-service/.env.example

# Python artifacts
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.venv/
**/venv/

# Node artifacts
**/node_modules/
**/build/
**/dist/
**/.npm/
**/.pnpm-store/

# IDE and OS artifacts
**/.idea/
**/.vscode/
**/.DS_Store
**/Thumbs.db

# Logs and temp
**/*.log
**/tmp/
**/temp/
**/.cache/
