# Realtime Voice Service Configuration
APP_ENV=development
LOG_LEVEL=INFO

SERVICE_HOST=localhost
SERVICE_PORT=5005

# Allow only the API Gateway origin(s) to call this service directly
API_GATEWAY_ORIGIN=http://localhost:5000
# Comma-separated list for extra trusted origins if needed
API_GATEWAY_ALLOWED_ORIGINS=

# Auto-enabled in production by default; set explicitly if needed
USE_PROXY_FIX=false
# Trust one reverse proxy hop by default
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
PROXY_FIX_X_PORT=1
PROXY_FIX_X_PREFIX=1

# OpenAI Realtime Configuration
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Conversation model — handles STT + LLM + TTS in one session
OPENAI_REALTIME_MODEL=gpt-4o-mini-realtime-preview

# Model used for user speech transcription within the session
OPENAI_REALTIME_TRANSCRIPTION_MODEL=whisper-1

OPENAI_REALTIME_LANGUAGE=nl
OPENAI_REALTIME_WS_URL=wss://api.openai.com/v1/realtime
OPENAI_REALTIME_API_BASE=https://api.openai.com/v1
OPENAI_REALTIME_USE_EPHEMERAL_TOKEN=false

# TTS voice: alloy, echo, fable, onyx, nova, shimmer
OPENAI_REALTIME_VOICE=alloy

# System prompt for the assistant
OPENAI_REALTIME_SYSTEM_PROMPT=Je bent een behulpzame taalassistent voor MBO-studenten. Reageer altijd in de taal die de gebruiker spreekt. Houd je antwoorden beknopt en duidelijk.

# Server-side VAD settings
OPENAI_REALTIME_VAD_THRESHOLD=0.5
OPENAI_REALTIME_VAD_SILENCE_MS=500
OPENAI_REALTIME_PREFIX_PADDING_MS=300

# Database manager integration
DATABASE_MANAGER_URL=http://localhost:5004

# OpenAI upstream websocket settings
OPENAI_WS_TIMEOUT_SEC=180
# Set to 0 to disable keepalive pings
OPENAI_WS_PING_INTERVAL_SEC=0

# Basic, standard request rate limit for HTTP endpoints
RATE_LIMIT_DEFAULT=120 per minute

# Production server tuning (Gunicorn)
WEB_CONCURRENCY=1
GUNICORN_WORKER_CLASS=geventwebsocket.gunicorn.workers.GeventWebSocketWorker
GUNICORN_TIMEOUT=180
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_LOG_LEVEL=info
