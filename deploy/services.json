{
  "gateway": {
    "name": "gateway",
    "workdir": "services/api-gateway",
    "start": "python api_gateway.py",
    "port": 5000,
    "env": {
      "PYTHONIOENCODING": "utf-8",
      "PYTHONUTF8": "1",
      "FLASK_ENV": "production"
    }
  },
  "services": [
    {
      "name": "database-manager",
      "workdir": "services/database-manager",
      "start": "python database_manager.py",
      "port": 5004,
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUTF8": "1"
      }
    },
    {
      "name": "realtime-voice",
      "workdir": "services/openai-service",
      "start": "python realtime_voice_service.py",
      "port": 5005,
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUTF8": "1"
      }
    }
  ]
}
