# API Gateway Configuration
APP_ENV=development
LOG_LEVEL=INFO
GATEWAY_HOST=localhost
GATEWAY_PORT=5000
FRONTEND_CHATBOT_ORIGIN=http://localhost:3000
FRONTEND_DASHBOARD_ORIGIN=http://localhost:3001
# Comma-separated list for additional frontends, for example:
# FRONTEND_ALLOWED_ORIGINS=https://chat.example.com,https://dashboard.example.com
FRONTEND_ALLOWED_ORIGINS=
RATE_LIMIT_DEFAULT=120 per minute
DATABASE_SERVICE_URL=http://localhost:5004
REALTIME_VOICE_SERVICE_URL=http://localhost:5005
REALTIME_VOICE_SERVICE_WS_URL=ws://localhost:5005/ws/realtime-voice
GATEWAY_BACKEND_WS_TIMEOUT_SEC=180
# Set to 0 to disable keepalive pings
GATEWAY_BACKEND_WS_PING_INTERVAL_SEC=0
# Auto-enabled in production by default; set explicitly if needed
USE_PROXY_FIX=false
# Trust one reverse proxy hop by default
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
PROXY_FIX_X_PORT=1
PROXY_FIX_X_PREFIX=1

# Production server tuning (Gunicorn)
WEB_CONCURRENCY=1
GUNICORN_WORKER_CLASS=geventwebsocket.gunicorn.workers.GeventWebSocketWorker
GUNICORN_TIMEOUT=180
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_LOG_LEVEL=info
