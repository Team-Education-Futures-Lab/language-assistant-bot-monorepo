APP_ENV=development
LOG_LEVEL=INFO
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SERVICE_PORT=5004
SERVICE_HOST=localhost

# Allow only API Gateway origin(s)
API_GATEWAY_ORIGIN=http://localhost:5000
# Comma-separated additional trusted origins if needed
API_GATEWAY_ALLOWED_ORIGINS=

# Basic, standard request rate limit for HTTP endpoints
RATE_LIMIT_DEFAULT=120 per minute

# Auto-enabled in production by default; set explicitly if needed
USE_PROXY_FIX=false
# Trust one reverse proxy hop by default
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
PROXY_FIX_X_PORT=1
PROXY_FIX_X_PREFIX=1

# Production server tuning (Gunicorn)
WEB_CONCURRENCY=1
GUNICORN_WORKER_CLASS=gthread
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=180
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_LOG_LEVEL=info

DB_HOST=db.xxxxx.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=postgres
COLLECTION_NAME=course_materials_vectors
DEFAULT_RETRIEVE_TOP_K=10
DEFAULT_RETRIEVE_TIMEOUT_SEC=8
